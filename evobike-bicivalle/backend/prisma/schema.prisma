generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductImage {
  id        String   @id @default(cuid())
  siigoCode String   @unique
  images    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  id        String   @id @default(cuid())
  siigoCode String   @unique
  category  String   // 'bicicleta' | 'scooter' | 'triciclo' | 'accesorio'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductGroup {
  id          String           @id @default(cuid())
  slug        String           @unique
  displayName String
  category    String
  description String?
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id         String       @id @default(cuid())
  groupId    String
  group      ProductGroup @relation(fields: [groupId], references: [id])
  siigoCode  String       @unique
  colorLabel String
  images     String[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VENDOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  VENDOR
}